# Orb QR auth proxy. Used for Lens access/refresh tokens.
ORB_AUTH_BASE_URL=https://new.orb.club/api
ORB_AUTH_ORIGIN=https://social-lens-bridge.local

# Local bridge state. The SQLite file is created with mode 0600.
BRIDGE_STATE_DB=./data/bridge.sqlite3

# Lens API and Grove storage. The Lens account is normally derived from the
# Orb/Lens access token saved by `bridge auth orb-qr`.
LENS_API_URL=https://api.lens.xyz/graphql
LENS_STORAGE_URL=https://api.grove.storage/
LENS_STORAGE_KEY_URL=https://api.grove.storage/link/new?amount=1
LENS_CHAIN_ID=232
X_GROVE_CLIENT=social-lens-bridge

# Optional override only. Leave blank unless you explicitly need to force a
# different Lens account than the one in the auth token.
LENS_ACCOUNT=

# Optional Lens auth tokens if you are not using the SQLite session from
# `bridge auth orb-qr`. LENS_ID_TOKEN alone is not enough. LENS_ACCESS_TOKEN
# alone is short-lived; add LENS_REFRESH_TOKEN for automatic refresh.
LENS_ID_TOKEN=
LENS_ACCESS_TOKEN=
LENS_REFRESH_TOKEN=

# Nostr account to bridge. This follows BlueNostr's nsec-in-env model.
# NOSTR_PUBLIC_KEY may be npub or 64-char hex. It is optional when NOSTR_NSEC
# or NOSTR_PRIVATE_KEY_HEX is set; the bridge derives it for inbound relay reads.
NOSTR_PUBLIC_KEY=
NOSTR_NSEC=nsec1...
NOSTR_PRIVATE_KEY_HEX=
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol
NOSTR_RELAY_READ_TIMEOUT_SECONDS=15

# Bluesky account to bridge.
BLUESKY_DID=did:plc:examplebridgeaccount
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=
BLUESKY_SERVICE_URL=https://bsky.social
BLUESKY_JETSTREAM_URL=wss://jetstream2.us-east.bsky.network/subscribe
BLUESKY_JETSTREAM_READ_TIMEOUT_SECONDS=15

# Bridge policy. Keep these conservative until live media posting is verified.
BRIDGE_POLL_INTERVAL_SECONDS=30
BRIDGE_MAX_MEDIA_ITEMS=4
BRIDGE_MAX_MEDIA_BYTES=5000000
